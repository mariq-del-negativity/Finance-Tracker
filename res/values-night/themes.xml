<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KeuanganKita" parent="Theme.MaterialComponents.DayNight.Bridge">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/textPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnSecondary">@color/textPrimary</item>
        <item name="android:windowBackground">@color/bgDark</item>
        <item name="android:statusBarColor">@color/bgDark</item>
        <item name="android:navigationBarColor">@color/bgDark</item>
        <item name="buttonStyle">@style/CustomButtonStyle</item>
    </style>

    <style name="CustomButtonStyle" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
