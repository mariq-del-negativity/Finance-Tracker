<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Pengeluaran"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jumlah (Rp)"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etJumlah"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textHint"
            android:hint="0"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keterangan"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etKeterangan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textHint"
            android:hint="Keterangan..."
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerKategori"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:layout_marginBottom="12dp"
            android:popupBackground="@color/bgCard" />

        <!-- Field kategori custom - muncul hanya kalau pilih "Lainnya" -->
        <TextView
            android:id="@+id/tvLabelKategoriCustom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Kategori"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etKategoriCustom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:padding="16dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textHint"
            android:hint="Tulis nama kategori..."
            android:inputType="text"
            android:singleLine="true"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBatal"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="BATAL"
                android:textColor="@color/textSecondary"
                android:textStyle="bold"
                android:background="@drawable/bg_button_secondary"
                android:layout_marginEnd="10dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSimpan"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="SIMPAN"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:layout_marginStart="10dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
