<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.keuangankita">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KeuanganKita">

        <!-- Login Activity sebagai launcher -->
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Home Activity -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />

        <!-- Tambah Pemasukan -->
        <activity
            android:name=".ui.transaksi.TambahPemasukanActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Tambah Pengeluaran -->
        <activity
            android:name=".ui.transaksi.TambahPengeluaranActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Riwayat Transaksi -->
        <activity
            android:name=".ui.riwayat.RiwayatActivity"
            android:exported="false" />

    </application>

</manifest>
